{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    "localstack-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@localstack/localstack-mcp-server"
      ]
    }
  }
}
